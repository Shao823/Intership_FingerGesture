
/emg_gesture_repro/

# Vivado project: track hand-written RTL/test sources and IP configuration only.
# Keep generated runs/cache/simulation/output products ignored.
/emg_gesture_vivado/*
!/emg_gesture_vivado/src/
!/emg_gesture_vivado/src/**
/emg_gesture_vivado/src/**/__pycache__/
/emg_gesture_vivado/src/**/*.pyc

!/emg_gesture_vivado/emg_gesture_vivado.srcs/
/emg_gesture_vivado/emg_gesture_vivado.srcs/*
!/emg_gesture_vivado/emg_gesture_vivado.srcs/sources_1/
/emg_gesture_vivado/emg_gesture_vivado.srcs/sources_1/*
!/emg_gesture_vivado/emg_gesture_vivado.srcs/sources_1/ip/
/emg_gesture_vivado/emg_gesture_vivado.srcs/sources_1/ip/*
!/emg_gesture_vivado/emg_gesture_vivado.srcs/sources_1/ip/*/
/emg_gesture_vivado/emg_gesture_vivado.srcs/sources_1/ip/*/*
!/emg_gesture_vivado/emg_gesture_vivado.srcs/sources_1/ip/*/*.xci
